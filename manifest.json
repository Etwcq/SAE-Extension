{
    "name": "SAE Extension",
    "version": "0.4.1",
    "manifest_version": 3,
    "description": "AE3(Academic Express 3)のおてつだいりゃ！",
    "icons": {
        "16": "./resources/icon16.png",
        "32": "./resources/icon32.png",
        "48": "./resources/icon48.png",
        "128": "./resources/icon128.png"
    },
    "permissions": [
        "storage",
        "notifications"
    ],
    "host_permissions": [
        "*://raw.githubusercontent.com/*",
        "*://script.google.com/*"
    ],
    "background": {
        "service_worker": "chrome/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*/as/lplayer/index.cfm*"
            ],
            "js": [
                "chrome/loader.js",
                "chrome/content.js"
            ]
        },
        {
            "matches": [
                "https://*/student/",
                "https://*/student/?token=*"
            ],
            "js": [
                "chrome/updatechecker.js"
            ]
        },
        {
            "matches": [
                "https://*/as/lplayer/index.cfm*"
            ],
            "js": [
                "chrome/onDocumentLoad.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "chrome/*",
                "modules/*",
                "lib/*"
            ],
            "matches": [
                "*://*/*"
            ]
        }
    ],
    "action": {
        "default_popup": "chrome/popup/index.html"
    }
}